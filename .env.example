# ==========================================
# 이 파일을 복사해서 .env 로 이름 변경 후 값을 채우세요
# cp .env.example .env
# ==========================================

VAD_SILENCE_THRESHOLD=0.5
VAD_SAMPLE_RATE=16000
VAD_CHUNK_SAMPLES=512

WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

CBT_LLM_USE_REAL=true
CBT_LLM_DEVICE=cuda
CBT_ADAPTER_PATH=models/cbt-counselor-final
CBT_LORA_DIR=models/lora

LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
LLM_DEVICE=cuda
LLM_USE_REAL=false

TEXT_EMOTION_USE_REAL=true
TEXT_EMOTION_MODEL_PATH=models/text-emotion-final
TEXT_EMOTION_DEVICE=cpu

AUDIO_EMOTION_USE_REAL=true
AUDIO_EMOTION_DEVICE=cpu
VOICE_EMOTION_MODEL_PATH=models/voice-emotion-final

FACE_EMOTION_USE_REAL=true

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
